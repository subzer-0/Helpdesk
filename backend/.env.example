NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Postgres. Local: postgres://postgres:postgres@localhost:5432/helpdesk
# Neon/Supabase: paste the connection string they give you
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/helpdesk?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173

# Redis (for BullMQ). Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Anthropic (optional — AI features disabled if missing)
ANTHROPIC_API_KEY=

# Inbound email webhook shared secret (for provider signing / HMAC)
EMAIL_WEBHOOK_SECRET=change-me-email-webhook

# Form intake shared secret — for POST /api/complaints/intake
# Integrator signs JSON body with HMAC-SHA256 and sends hex in X-Webhook-Signature.
FORM_WEBHOOK_SECRET=change-me-form-webhook
